---
/*
  Header corporativo: logo grande, navegación real y CTA angular
  (esquinas rectas, como el resto de la identidad blueprint).
  El contacto y las redes viven en el footer.
*/
const links = [
  { href: '/cursos', label: 'Cursos' },
  { href: '/#nosotros', label: 'Nosotros' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#empresas', label: 'Empresas' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-[0_1px_0_0_#d5e4f5,0_8px_24px_-16px_rgba(11,42,74,0.25)]">
  <!-- Barra principal -->
  <nav class="relative mx-auto flex max-w-6xl items-center justify-between px-4 py-2">
    <a href="/" class="flex items-center gap-4" aria-label="Well Solutions — inicio">
      <img
        src="/logo-navy.png"
        alt="Well Solutions"
        class="h-16 w-auto sm:h-[4.75rem]"
        width="1220"
        height="540"
      />
      <span class="hidden h-8 w-px bg-brand-200 sm:block"></span>
      <span class="hidden font-display text-[15px] font-semibold leading-tight tracking-tight text-brand-800 sm:block">
        Academia de<br />Petróleo y Gas
      </span>
    </a>

    <!-- Navegación desktop -->
    <div class="hidden items-center gap-9 lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="group relative text-[13px] font-semibold uppercase tracking-[0.14em] text-brand-900 transition hover:text-brand-500"
          >
            {l.label}
            <span class="absolute -bottom-1.5 left-0 h-0.5 w-0 bg-cyan-400 transition-all duration-200 group-hover:w-full" />
          </a>
        ))
      }
      <a
        href="/cursos"
        class="border-b-2 border-cyan-400 bg-brand-950 px-7 py-3 text-[13px] font-bold uppercase tracking-[0.14em] text-white transition hover:bg-brand-800"
      >
        Empezar
      </a>
    </div>

    <!-- Menú mobile -->
    <details class="lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center border border-brand-200 text-brand-900 [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menú"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </summary>
      <div class="absolute inset-x-0 top-full flex flex-col border-t border-brand-100 bg-white shadow-lg">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="border-b border-brand-50 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-brand-900"
            >
              {l.label}
            </a>
          ))
        }
        <a
          href="/cursos"
          class="m-4 border-b-2 border-cyan-400 bg-brand-950 px-6 py-3.5 text-center text-sm font-bold uppercase tracking-[0.14em] text-white"
        >
          Empezar
        </a>
      </div>
    </details>
  </nav>
</header>
