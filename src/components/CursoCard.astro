---
import { formatArs, nivelLabel } from '../lib/format';
import type { CollectionEntry } from 'astro:content';

interface Props {
  curso: CollectionEntry<'cursos'>;
}

const { curso } = Astro.props;
const { titulo, nivel, resumen, precio, temario, duracion } = curso.data;

// Acento de color y barra superior según el nivel.
const nivelStyle: Record<string, { text: string; bar: string; dot: string }> = {
  principiante: { text: 'text-emerald-600', bar: 'bg-emerald-400', dot: 'bg-emerald-400' },
  intermedio: { text: 'text-cyan-600', bar: 'bg-cyan-400', dot: 'bg-cyan-400' },
  avanzado: { text: 'text-brand-600', bar: 'bg-brand-500', dot: 'bg-brand-500' },
};
const estilo = nivelStyle[nivel];
const modulos = temario?.length ?? 0;
---

<a
  href={`/cursos/${curso.id}`}
  class="group relative flex flex-col overflow-hidden rounded-xl border border-brand-200 bg-white transition duration-300 hover:-translate-y-1 hover:border-cyan-400 hover:shadow-xl hover:shadow-brand-500/10"
>
  <!-- Barra de acento según nivel -->
  <span class={`h-1 w-full ${estilo.bar}`}></span>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center gap-2">
      <span class={`h-1.5 w-1.5 rounded-full ${estilo.dot}`}></span>
      <span class={`spec-label ${estilo.text}`}>Nivel · {nivelLabel[nivel]}</span>
    </div>

    <h3
      class="mt-3 font-display text-xl font-bold leading-snug text-brand-900 transition group-hover:text-brand-600"
    >
      {titulo}
    </h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-500">{resumen}</p>

    <!-- Meta: módulos y duración -->
    <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-medium text-slate-500">
      {modulos > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5 text-brand-400" aria-hidden="true"><path d="M3 4.5A1.5 1.5 0 0 1 4.5 3h11A1.5 1.5 0 0 1 17 4.5v11a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 3 15.5v-11ZM6 7h8M6 10h8M6 13h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"></path></svg>
          {modulos} módulos
        </span>
      )}
      {duracion && (
        <span class="inline-flex items-center gap-1.5">
          <svg viewBox="0 0 20 20" fill="none" class="h-3.5 w-3.5 text-brand-400" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.2"></circle><path d="M10 6v4l2.5 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path></svg>
          {duracion}
        </span>
      )}
    </div>

    <div
      class="mt-6 flex items-center justify-between border-t border-brand-100 pt-4"
    >
      <div>
        <span class="block text-[0.65rem] uppercase tracking-wider text-slate-400">Desde</span>
        <span class="font-mono text-lg font-bold text-brand-900">
          {formatArs(precio.ars)}
        </span>
      </div>
      <span
        class="inline-flex items-center gap-1.5 rounded-lg bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-700 transition group-hover:bg-cyan-400 group-hover:text-brand-950"
      >
        Ver curso
        <span class="transition group-hover:translate-x-0.5">→</span>
      </span>
    </div>
  </div>
</a>
