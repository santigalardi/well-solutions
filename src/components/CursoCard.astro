---
import { formatArs, nivelLabel } from '../lib/format';
import type { CollectionEntry } from 'astro:content';

interface Props {
  curso: CollectionEntry<'cursos'>;
}

const { curso } = Astro.props;
const { titulo, nivel, resumen, precio } = curso.data;

const nivelColor: Record<string, string> = {
  principiante: 'bg-brand-100 text-brand-800',
  intermedio: 'bg-brand-200 text-brand-900',
  avanzado: 'bg-brand-800 text-white',
};
---

<a
  href={`/cursos/${curso.id}`}
  class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg"
>
  <span
    class={`mb-3 inline-flex w-fit rounded-full px-3 py-1 text-xs font-semibold ${nivelColor[nivel]}`}
  >
    {nivelLabel[nivel]}
  </span>
  <h3 class="text-lg font-bold text-slate-900 group-hover:text-brand-700">
    {titulo}
  </h3>
  <p class="mt-2 flex-1 text-sm text-slate-500">{resumen}</p>
  <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
    <span class="text-lg font-bold text-slate-900">{formatArs(precio.ars)}</span>
    <span class="text-sm font-medium text-brand-600 group-hover:underline">
      Ver curso →
    </span>
  </div>
</a>
