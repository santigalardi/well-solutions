---
const year = new Date().getFullYear();
// Contacto real (del sitio actual del cliente).
const whatsapp = '5492995335935';
const email = 'Wellsolutionadvisor@gmail.com';
const linkedin = 'https://www.linkedin.com/in/jos%C3%A9-luis-barros-0822a412b';
const facebook = 'https://www.facebook.com/joseluis.barros.3';
---

<footer id="contacto" class="relative overflow-hidden bg-brand-950 text-white">
  <div class="absolute -left-32 -top-20 h-80 w-80 rounded-full bg-brand-500/15 blur-[130px]"></div>

  <div class="relative mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-12 sm:grid-cols-[1.6fr_1fr_1.2fr]">
      <!-- Marca -->
      <div>
        <img
          src="/logo-white.png"
          alt="Well Solutions"
          class="h-16 w-auto"
          width="1220"
          height="540"
        />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-brand-100/80">
          Advisors Producción Oil y Gas. Formamos líderes y operadores con 20 años
          de know-how en Vaca Muerta.
        </p>
        <!-- Redes -->
        <div class="mt-6 flex items-center gap-3">
          <a
            href={linkedin}
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/15 text-brand-100 transition hover:border-cyan-400 hover:bg-cyan-400 hover:text-brand-950"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45z"></path></svg>
          </a>
          <a
            href={facebook}
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/15 text-brand-100 transition hover:border-cyan-400 hover:bg-cyan-400 hover:text-brand-950"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.02 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.7 4.53-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8V24C19.61 23.09 24 18.09 24 12.07z"></path></svg>
          </a>
          <a
            href={`https://wa.me/${whatsapp}`}
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/15 text-brand-100 transition hover:border-cyan-400 hover:bg-cyan-400 hover:text-brand-950"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.7.63.71.23 1.36.19 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35zM12.05 21.5c-1.67 0-3.31-.45-4.74-1.29l-.34-.2-3.52.92.94-3.43-.22-.35a9.42 9.42 0 0 1-1.44-5.02c0-5.22 4.25-9.47 9.48-9.47 2.53 0 4.9.99 6.69 2.78a9.4 9.4 0 0 1 2.77 6.7c-.01 5.22-4.26 9.47-9.47 9.47zm8.06-17.54A11.32 11.32 0 0 0 12.05.5C5.79.5.7 5.59.69 11.85c0 2.01.53 3.97 1.53 5.7L.6 23.5l6.1-1.6a11.32 11.32 0 0 0 5.35 1.36h.01c6.26 0 11.35-5.09 11.36-11.35a11.29 11.29 0 0 0-3.32-8.03z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Navegación -->
      <div>
        <p class="spec-label text-cyan-400">Navegación</p>
        <nav class="mt-5 flex flex-col gap-3 text-sm font-medium text-brand-100/90">
          <a href="/cursos" class="w-fit transition hover:text-cyan-400">Cursos</a>
          <a href="/#nosotros" class="w-fit transition hover:text-cyan-400">Nosotros</a>
          <a href="/#servicios" class="w-fit transition hover:text-cyan-400">Servicios</a>
          <a href="/#empresas" class="w-fit transition hover:text-cyan-400">Para empresas</a>
          <a href="/#contacto" class="w-fit transition hover:text-cyan-400">Contacto</a>
        </nav>
      </div>

      <!-- Contacto -->
      <div>
        <p class="spec-label text-cyan-400">Contacto</p>
        <div class="mt-5 flex flex-col gap-3.5 text-sm text-brand-100/90">
          <a
            href={`https://wa.me/${whatsapp}`}
            class="group flex items-center gap-3 transition hover:text-cyan-400"
            target="_blank"
            rel="noopener"
          >
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0 text-cyan-400" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            +54 9 299 533 5935
          </a>
          <a href={`mailto:${email}`} class="group flex items-center gap-3 break-all transition hover:text-cyan-400">
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0 text-cyan-400" aria-hidden="true"><rect x="2.5" y="4.5" width="19" height="15" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="m3 6 9 6 9-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
            {email}
          </a>
          <span class="flex items-center gap-3 text-brand-100/70">
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0 text-cyan-400" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"></circle></svg>
            Neuquén, Argentina
          </span>
        </div>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-brand-100/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Well Solutions · Advisors Producción Oil y Gas.</p>
      <p class="spec-label text-brand-100/50">Academia de Petróleo y Gas</p>
    </div>
  </div>
</footer>
