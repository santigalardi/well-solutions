---
import Base from '../layouts/Base.astro';
/*
  Página estática: el estado (aprobado/pendiente) llega por query param
  (?estado=pendiente) y se resuelve con un script en el cliente, porque
  en build no hay searchParams.
*/
---

<Base title="¡Gracias por tu compra! · Well Solutions">
  <section class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 bg-blueprint-dark opacity-60"></div>
    <div class="relative mx-auto max-w-2xl px-4 py-28 text-center">
      <div
        class="corner-ticks mx-auto flex h-20 w-20 items-center justify-center border border-cyan-400/50 bg-brand-900/60 font-display text-3xl font-bold text-cyan-400"
      >
        <span data-icono>✓</span>
      </div>

      <h1 class="mt-8 font-display text-4xl font-extrabold tracking-tight" data-titulo>
        ¡Gracias por tu compra!
      </h1>
      <p class="mx-auto mt-5 max-w-lg text-lg text-brand-100/80" data-mensaje>
        Recibimos tu pago. En breve te damos de alta en el aula online y te
        llega el acceso por email.
      </p>

      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
        <a
          href="/cursos"
          class="rounded-xl bg-cyan-400 px-8 py-4 font-bold text-brand-950 transition hover:bg-cyan-300"
        >
          Ver más cursos
        </a>
        <a
          href="https://wa.me/5492995335935"
          target="_blank"
          rel="noopener"
          class="rounded-xl border border-white/20 px-8 py-4 font-semibold text-white transition hover:border-cyan-400 hover:text-cyan-400"
        >
          ¿Dudas? WhatsApp
        </a>
      </div>
    </div>
  </section>
</Base>

<script>
  // Variante "pago pendiente" según query param.
  if (new URLSearchParams(location.search).get('estado') === 'pendiente') {
    document.querySelector('[data-icono]')!.textContent = '⏳';
    document.querySelector('[data-titulo]')!.textContent = 'Tu pago está en proceso';
    document.querySelector('[data-mensaje]')!.textContent =
      'En cuanto se acredite el pago, te damos de alta en el aula y recibís el acceso por email.';
  }
</script>
