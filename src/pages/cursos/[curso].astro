---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BotonComprar from '../../components/BotonComprar.astro';
import { formatArs, formatUsd, nivelLabel } from '../../lib/format';

// Genera una página estática por cada curso publicado.
export async function getStaticPaths() {
  const cursos = await getCollection('cursos', ({ data }) => data.publicado);
  return cursos.map((curso) => ({
    params: { curso: curso.id },
    props: { curso },
  }));
}

const { curso } = Astro.props;
const { titulo, nivel, resumen, temario, duracion, precio } = curso.data;
const { Content } = await render(curso);
---

<Base title={`${titulo} · Well Solutions`} description={resumen}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <a href="/cursos" class="text-sm font-medium text-brand-600 hover:underline">
      ← Volver a los cursos
    </a>

    <div class="mt-6 grid gap-12 lg:grid-cols-[1fr_320px]">
      <!-- Contenido -->
      <div>
        <span class="inline-flex rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold text-brand-800">
          Nivel {nivelLabel[nivel]}
        </span>
        <h1 class="mt-4 text-4xl font-black text-slate-900">{titulo}</h1>
        <p class="mt-4 text-lg text-slate-600">{resumen}</p>

        <h2 class="mt-10 text-xl font-bold text-slate-900">Qué vas a ver</h2>
        <ul class="mt-4 space-y-2">
          {
            temario.map((item) => (
              <li class="flex items-start gap-3 text-slate-700">
                <span class="mt-1 text-brand-600">✓</span>
                {item}
              </li>
            ))
          }
        </ul>

        <div class="prose prose-slate mt-10 max-w-none">
          <Content />
        </div>
      </div>

      <!-- Card de compra (sticky) -->
      <aside class="lg:sticky lg:top-24 lg:h-fit">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-3xl font-black text-slate-900">{formatArs(precio.ars)}</p>
          {
            precio.usd && (
              <p class="mt-1 text-sm text-slate-400">≈ {formatUsd(precio.usd)}</p>
            )
          }
          {duracion && <p class="mt-3 text-sm text-slate-500">{duracion}</p>}

          <div class="mt-6">
            <BotonComprar cursoId={curso.id} titulo={titulo} />
          </div>

          <ul class="mt-6 space-y-2 text-sm text-slate-500">
            <li>✓ Acceso al aula online</li>
            <li>✓ Videos, audios y evaluaciones</li>
            <li>✓ Avanzás a tu ritmo</li>
            <li>✓ Comunidad de consultas</li>
          </ul>
        </div>
      </aside>
    </div>
  </article>
</Base>
