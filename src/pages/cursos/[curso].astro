---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BotonComprar from '../../components/BotonComprar.astro';
import { formatArs, formatUsd, nivelLabel } from '../../lib/format';

// Genera una página estática por cada curso publicado.
export async function getStaticPaths() {
  const cursos = await getCollection('cursos', ({ data }) => data.publicado);
  return cursos.map((curso) => ({
    params: { curso: curso.id },
    props: { curso },
  }));
}

const { curso } = Astro.props;
const { titulo, nivel, resumen, temario, duracion, precio } = curso.data;
const { Content } = await render(curso);

// Acento de color por nivel (coherente con las cards del catálogo).
const nivelAccent: Record<string, { text: string; bar: string; dot: string; chip: string }> = {
  principiante: { text: 'text-emerald-400', bar: 'bg-emerald-400', dot: 'bg-emerald-400', chip: 'border-emerald-400/40 text-emerald-300' },
  intermedio: { text: 'text-cyan-400', bar: 'bg-cyan-400', dot: 'bg-cyan-400', chip: 'border-cyan-400/40 text-cyan-300' },
  avanzado: { text: 'text-brand-300', bar: 'bg-brand-400', dot: 'bg-brand-400', chip: 'border-brand-300/40 text-brand-200' },
};
const acento = nivelAccent[nivel];
---

<Base title={`${titulo} · Well Solutions`} description={resumen}>
  <!-- Cabecera navy del curso -->
  <section class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute -left-32 top-0 h-96 w-96 rounded-full bg-brand-500/20 blur-[130px]"></div>
    <div class="absolute -right-20 bottom-0 h-80 w-80 rounded-full bg-cyan-400/10 blur-[120px]"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-16">
      <a href="/cursos" class="spec-label text-brand-100/70 transition hover:text-cyan-400">
        ← Todos los cursos
      </a>
      <div class="mt-6 flex items-center gap-3">
        <span class={`h-px w-10 ${acento.bar}`}></span>
        <p class={`spec-label ${acento.text}`}>Curso · Nivel {nivelLabel[nivel]}</p>
      </div>
      <h1 class="mt-4 max-w-3xl font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        {titulo}
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-brand-100">{resumen}</p>

      <!-- Meta badges -->
      <div class="mt-8 flex flex-wrap gap-3">
        <span class={`inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium ${acento.chip}`}>
          <span class={`h-1.5 w-1.5 rounded-full ${acento.dot}`}></span>
          Nivel {nivelLabel[nivel]}
        </span>
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-4 py-1.5 text-sm font-medium text-brand-100">
          <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 text-cyan-400" aria-hidden="true"><path d="M3 4.5A1.5 1.5 0 0 1 4.5 3h11A1.5 1.5 0 0 1 17 4.5v11a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 3 15.5v-11ZM6 7h8M6 10h8M6 13h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path></svg>
          {temario.length} módulos
        </span>
        {duracion && (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-4 py-1.5 text-sm font-medium text-brand-100">
            <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 text-cyan-400" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.2"></circle><path d="M10 6v4l2.5 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path></svg>
            {duracion}
          </span>
        )}
      </div>
    </div>
  </section>

  <article class="bg-paper">
    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 lg:grid-cols-[1fr_340px]">
      <!-- Contenido -->
      <div>
        <div class="flex items-center gap-3">
          <span class="h-px w-10 bg-brand-500"></span>
          <h2 class="spec-label text-brand-500">Temario · {temario.length} módulos</h2>
        </div>
        <ul class="mt-6 divide-y divide-brand-100 overflow-hidden rounded-xl border border-brand-200 bg-white">
          {
            temario.map((item, i) => (
              <li class="group flex items-center gap-4 px-5 py-4 text-slate-700 transition hover:bg-brand-50">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 font-mono text-xs font-bold text-cyan-600 transition group-hover:bg-cyan-400 group-hover:text-brand-950">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="font-medium">{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="prose prose-slate mt-12 max-w-none">
          <Content />
        </div>
      </div>

      <!-- Card de compra (sticky) -->
      <aside class="lg:sticky lg:top-24 lg:h-fit">
        <div class="overflow-hidden rounded-2xl border border-brand-200 bg-white shadow-xl shadow-brand-500/5">
          <!-- Barra de acento por nivel -->
          <span class={`block h-1 w-full ${acento.bar}`}></span>
          <div class="p-6">
            <p class="spec-label text-slate-400">Inversión</p>
            <div class="mt-2 flex items-baseline gap-2">
              <p class="font-mono text-4xl font-bold text-brand-900">
                {formatArs(precio.ars)}
              </p>
            </div>
            {
              precio.usd && (
                <p class="mt-1 font-mono text-sm text-slate-400">
                  ≈ {formatUsd(precio.usd)}
                </p>
              )
            }
            {duracion && (
              <p class="mt-3 inline-flex items-center gap-2 text-sm text-slate-500">
                <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 text-cyan-500" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.2"></circle><path d="M10 6v4l2.5 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path></svg>
                {duracion}
              </p>
            )}

            <div class="mt-6">
              <BotonComprar cursoId={curso.id} titulo={titulo} />
            </div>

            <p class="mt-5 spec-label text-slate-400">Incluye</p>
            <ul class="mt-3 space-y-3 text-sm text-slate-600">
              {
                [
                  'Acceso al aula online',
                  'Videos, audios y evaluaciones',
                  'Avanzás a tu ritmo',
                  'Comunidad de consultas',
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <svg viewBox="0 0 20 20" fill="currentColor" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-500" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.79 6.8-6.79a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>

            <a
              href="https://wa.me/5492995335935"
              target="_blank"
              rel="noopener"
              class="mt-6 flex items-center justify-center gap-2 border-t border-brand-100 pt-4 text-center text-sm font-semibold text-brand-600 transition hover:text-cyan-500"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.7.63.71.23 1.36.19 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35z"></path></svg>
              ¿Dudas? Escribinos por WhatsApp
            </a>
          </div>
        </div>
      </aside>
    </div>
  </article>
</Base>
